# ============================================================
# .env.example — audithygiène
# Copie ce fichier en .env.local et remplis les valeurs.
# .env.local est ignoré par git. NE JAMAIS commiter de secrets.
# Détail de chaque clé : voir KIT_DE_CONNEXION.md
# ============================================================

# --- App ---
NEXT_PUBLIC_SITE_URL="https://audithygiene.fr"
NEXT_PUBLIC_APP_URL="https://app.audithygiene.fr"

# --- Vérification moteurs de recherche (SEO) ---
# Google Search Console : jeton de la balise "meta tag" (valeur de content uniquement).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
# Bing Webmaster Tools : valeur de la balise msvalidate.01.
NEXT_PUBLIC_BING_SITE_VERIFICATION=""

# --- Base de données : Supabase / Postgres (🔴 BLOQUANT) ---
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"
SUPABASE_STORAGE_BUCKET="rapports"

# --- Auth (généré en interne) ---
AUTH_SECRET="[openssl rand -base64 32]"

# --- Telegram (🟠) ---
TELEGRAM_BOT_TOKEN="[BOTFATHER_TOKEN]"
TELEGRAM_CHAT_ID="[CHAT_ID]"

# --- Brevo (🟠) ---
BREVO_API_KEY="[BREVO_API_KEY]"
BREVO_SENDER_EMAIL="contact@audithygiene.fr"
BREVO_SENDER_NAME="audit hygiène"

# --- Stripe (🟢 — mode test d'abord) ---
STRIPE_SECRET_KEY="sk_test_[...]"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_[...]"
STRIPE_WEBHOOK_SECRET="whsec_[...]"

# --- Yousign (🟢) ---
YOUSIGN_API_KEY="[YOUSIGN_API_KEY]"
YOUSIGN_API_URL="https://api-sandbox.yousign.app/v3"

# --- Google (🟠/🟢) ---
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_SHEET_ID=""

# --- Sauvegarde photos sur Google Drive (Shared Drive Workspace) ---
# Dormant tant que ces 2 variables ne sont pas remplies (aucun impact sinon).
# Clé JSON du compte de service, encodée en base64 (une seule ligne) :
#   base64 -w0 service-account.json   (ou : certutil -encode sous Windows)
GOOGLE_SERVICE_ACCOUNT_B64=""
# Id du Shared Drive (dans l'URL : drive.google.com/drive/folders/<ID>)
GOOGLE_DRIVE_ID=""
# Option : id d'un dossier DANS le Shared Drive où ranger les audits (sinon racine)
GOOGLE_DRIVE_PARENT_ID=""

# --- Vercel (CI/CD — optionnel en local) ---
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""

# --- Cron (généré en interne) ---
CRON_SECRET="[openssl rand -hex 16]"

# --- IA : restitution auditresto360 (clé Anthropic directe) ---
ANTHROPIC_API_KEY="sk-ant-[...]"
ANTHROPIC_MODEL="claude-sonnet-4-6"
